# Hermes Railway template environment variables
# Set these in Railway service Variables.
# You can also configure most of these from /setup (saved to HERMES_HOME/.env).

# Required: LLM provider key (OpenRouter is simplest for one-click setup).
OPENROUTER_API_KEY=

# Optional model override. If not set, Hermes falls back to its default model.
LLM_MODEL=anthropic/claude-sonnet-4

# Hermes child process API server runs behind the setup wrapper proxy.
# Wrapper routes /v1/* and /health traffic to Hermes internal API server.
API_SERVER_KEY=${{secret(48, "abcdefghijklmnopqrstuvwxyz0123456789")}}

# Access control defaults (recommended for public deploys).
GATEWAY_ALLOW_ALL_USERS=false

# Optional messaging platform tokens (set whichever platforms you use).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# TELEGRAM_HOME_CHANNEL=
# TELEGRAM_HOME_CHANNEL_NAME=

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=

# Optional: receive webhooks with Hermes route handling.
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8644
# WEBHOOK_SECRET=${{secret(48, "abcdefghijklmnopqrstuvwxyz0123456789")}}

# Optional: persistent profile location inside container.
HERMES_HOME=/data/hermes
